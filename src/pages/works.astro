---
import BaseLayout from "../layouts/BaseLayout.astro";
import { projects } from "../data/projects";
---

<BaseLayout title="Works">
  <section class="archive-page-title">
    <p class="eyebrow">Works</p>
    <h1>Works</h1>
  </section>

  <section class="works-gallery" aria-label="Project archive">
    {projects.map((project) => (
      <a class="work-card" href={`/works/${project.slug}/`}>
        <figure>
          <img src={project.thumbnail} alt="" loading="lazy" decoding="async" />
          <figcaption>
            <span>Cai Dongchen</span>
            <strong>{project.title}</strong>
            <span>{project.year}</span>
            <span>{project.format}</span>
          </figcaption>
        </figure>
      </a>
    ))}
  </section>
</BaseLayout>
