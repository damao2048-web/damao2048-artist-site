---
import BaseLayout from "../layouts/BaseLayout.astro";
import I18nBlock from "../components/I18nBlock.astro";
import { projects } from "../data/projects";
---

<BaseLayout title="Works">
  <section class="archive-page-title">
    <p class="eyebrow">Works</p>
    <h1>Works</h1>
    <I18nBlock
      className="quiet-intro"
      en="Projects are arranged chronologically from 2025 downward. Silent Ride is archived within Four Rumors, following the structure of the portfolio."
      ja="作品は2025年を起点に時系列で整理する。Silent Ride はポートフォリオの構成に従い、四つの噂の中に収録する。"
      zh="作品从 2025 年开始按时间顺序向下整理。Silent Ride 根据作品集结构归入《四つの噂》，不再单独列为项目。"
    />
  </section>

  <nav class="archive-tabs" aria-label="Works sections">
    <a class="is-active" href="/works/">Works</a>
    <a href="/cv/">Exhibitions / CV</a>
    <a href="/statement/">Statement</a>
  </nav>

  <section class="works-gallery" aria-label="Project archive">
    {projects.map((project) => (
      <a class="work-card" href={`/works/${project.slug}/`}>
        <figure>
          <img src={project.thumbnail} alt="" loading="lazy" decoding="async" />
          <figcaption>
            <span>Cai Dongchen / 蔡東辰</span>
            <strong>{project.title}</strong>
            <span>{project.year}</span>
            <span>{project.format}</span>
          </figcaption>
        </figure>
      </a>
    ))}
  </section>
</BaseLayout>
