---
import BaseLayout from "../layouts/BaseLayout.astro";
import { awards, education, exhibitions } from "../data/cv";
---

<BaseLayout title="CV">
  <section class="cv-page">
    <div class="cv-heading">
      <div>
        <p class="eyebrow">CV / Exhibitions</p>
        <h1>Curriculum Vitae</h1>
      </div>
      <a class="download-link" href="/files/cai-dongchen-cv.pdf" download>
        Download CV
      </a>
    </div>

    <section class="cv-section">
      <h2>Education</h2>
      <dl>
        {education.map((item) => (
          <div>
            <dt>{item.year}</dt>
            <dd>{item.text}</dd>
          </div>
        ))}
      </dl>
    </section>

    <section class="cv-section">
      <h2>Exhibitions</h2>
      <dl>
        {exhibitions.map((item) => (
          <div>
            <dt>{item.year}</dt>
            <dd>{item.text}</dd>
          </div>
        ))}
      </dl>
    </section>

    <section class="cv-section">
      <h2>Awards / Selected Competitions</h2>
      <dl>
        {awards.map((item) => (
          <div>
            <dt>{item.year}</dt>
            <dd>{item.text}</dd>
          </div>
        ))}
      </dl>
    </section>
  </section>
</BaseLayout>
