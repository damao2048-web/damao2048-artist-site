---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";

const archiveLinks = site.nav.filter((item) => item.href !== "/");
---

<BaseLayout title="Home" description={site.description}>
  <section class="home-index" aria-label="Artist index">
    <div class="home-index-primary">
      <h1>Cai Dongchen</h1>
      <p class="home-subtitle">Visual artist based in Tokyo</p>
      <p class="home-statement">
        Working through painting, sculpture, installation, performance, and fictional archives, Cai Dongchen explores rumors, misreadings, and narrative structures.
      </p>
    </div>

    <nav class="home-index-nav" aria-label="Artist archive">
      {archiveLinks.map((item) => (
        <a href={item.href}>
          <span>{item.label}</span>
          <small>
            {item.label === "Works" && "Archive of projects and documentation"}
            {item.label === "Statement" && "Artist statement"}
            {item.label === "CV" && "Exhibitions, education, and selected activities"}
            {item.label === "Contact" && "Email, Instagram, and location"}
          </small>
        </a>
      ))}
    </nav>
  </section>
</BaseLayout>
