---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ArtworkFigure from "../../components/ArtworkFigure.astro";
import { projects } from "../../data/projects";

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project }
  }));
}

const { project } = Astro.props;
---

<BaseLayout title={project.title}>
  <article class="project-page">
    <a class="back-link" href="/works/">All Works</a>

    <header class="project-detail-header">
      <div>
        <p class="eyebrow">Works</p>
        <h1>{project.title}</h1>
      </div>

      <dl class="project-meta">
        <div>
          <dt>Year</dt>
          <dd>{project.year}</dd>
        </div>
        {project.venue && (
          <div>
            <dt>Venue</dt>
            <dd>{project.venue}</dd>
          </div>
        )}
        <div>
          <dt>Medium</dt>
          <dd>{project.medium}</dd>
        </div>
        {project.details?.map((detail) => (
          <div>
            <dt>{detail.label}</dt>
            <dd>{detail.value}</dd>
          </div>
        ))}
      </dl>
    </header>

    <p class="project-description">{project.description}</p>

    <section
      class:list={["project-image-archive", project.imageFit === "contain" && "is-contain"]}
      aria-label={`${project.title} images`}
    >
      {project.images.map((artwork, index) => (
        <ArtworkFigure image={artwork} eager={index === 0} />
      ))}
    </section>
  </article>
</BaseLayout>
