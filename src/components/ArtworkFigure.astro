---
import type { ArtworkImage } from "../data/projects";

type Props = {
  image: ArtworkImage;
  eager?: boolean;
};

const { image, eager = false } = Astro.props;
---

<figure class="artwork-figure">
  <button
    class="artwork-image-button"
    type="button"
    data-lightbox-src={image.src}
    data-lightbox-alt={image.alt}
    data-lightbox-caption={image.caption}
    aria-label={`View image: ${image.caption}`}
  >
    <img
      src={image.src}
      alt={image.alt}
      loading={eager ? "eager" : "lazy"}
      decoding="async"
    />
  </button>
  <figcaption>{image.caption}</figcaption>
</figure>
