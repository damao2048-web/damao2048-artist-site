---
import type { ArtworkImage } from "../data/projects";

type Props = {
  image: ArtworkImage;
  eager?: boolean;
};

const { image, eager = false } = Astro.props;
---

<figure class="artwork-figure">
  <img
    src={image.src}
    alt={image.alt}
    loading={eager ? "eager" : "lazy"}
    decoding="async"
  />
  <figcaption>{image.caption}</figcaption>
</figure>
