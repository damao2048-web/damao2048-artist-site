---
type Props = {
  en: string;
  ja: string;
  zh: string;
  as?: "p" | "span" | "div";
  className?: string;
};

const { en, ja, zh, as = "p", className = "" } = Astro.props;
const Tag = as;
---

<Tag class={className} data-lang="en">{en}</Tag>
<Tag class={className} data-lang="ja">{ja}</Tag>
<Tag class={className} data-lang="zh">{zh}</Tag>
